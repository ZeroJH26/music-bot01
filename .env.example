# Required — get from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Optional — comma-separated Telegram user IDs allowed to use the bot
# Leave empty to allow everyone
ALLOWED_USERS=123456789,987654321

# Optional — Spotify credentials for full artist/title metadata on Spotify links
# Get them at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Download directory (created automatically)
DOWNLOADS_DIR=downloads

# MP3 bitrate: 128 | 192 | 256 | 320
AUDIO_QUALITY=320
